{
  "name": "gateclerk-terminal",
  "version": "1.0.20",
  "description": "GateClerk Gate Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w usb",
    "build": "npm run rebuild && electron-builder --win --x64",
    "build:unsigned": "npm run rebuild && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gateclerk.terminal",
    "productName": "GateClerk",
    "copyright": "Copyright Â© 2026 StormPay Inc.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "GateClerk"
    },
    "publish": {
      "provider": "github",
      "owner": "4473PRO",
      "repo": "gateclerk-terminal"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "usb": "^2.11.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
